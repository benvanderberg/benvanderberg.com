---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  canonicalUrl?: string;
}
const { title, description, pubDate, updatedDate, heroImage, canonicalUrl } = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} image={heroImage} ogType="article">
  <article class="article">
    <h1>{title}</h1>
    <span class="meta">
      {fmt(pubDate)}
      {updatedDate && <> · Updated {fmt(updatedDate)}</>}
    </span>
    {heroImage && <img class="hero-img" src={heroImage} alt="" />}
    <div class="article-body">
      <slot />
    </div>
    <hr />
    <p><a href="/blog/">← All posts</a></p>
  </article>
</BaseLayout>
