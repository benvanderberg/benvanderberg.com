---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site.config';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  canonicalUrl?: string;
}
const { title, description = site.description, wide = false, canonicalUrl } = Astro.props;
const fullTitle = title ? `${title} — ${site.title}` : site.title;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-EKNK7E8PJW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EKNK7E8PJW');
    </script>
  </head>
  <body>
    <Header />
    <main data-pagefind-body>
      <div class={wide ? 'container-wide' : 'container'}>
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
