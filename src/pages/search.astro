---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Search" description="Search across blog posts, events, and videos.">
  <h1>Search</h1>
  <p style="color: var(--muted);">Search across the whole site — blog posts, events, and videos.</p>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="search" data-pagefind-ignore="all"></div>

  <noscript>
    <p style="color: var(--muted); margin-top: 2rem;">
      Search requires JavaScript. You can still browse the site via the links above.
    </p>
  </noscript>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI !== 'function') {
        // The search index is generated by `pagefind --site dist` during build.
        // In `astro dev` it does not exist; show a friendly note instead.
        const el = document.getElementById('search');
        if (el) {
          el.innerHTML =
            '<p style="color: var(--muted);">Search index isn\'t built in dev mode. Run <code>npm run build && npm run preview</code> to try it.</p>';
        }
        return;
      }
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        resetStyles: false,
      });
    });
  </script>

  <style is:global>
    /* Pagefind UI overrides to match the site's black/white aesthetic */
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: #0a0a0a;
      --pagefind-ui-text: #0a0a0a;
      --pagefind-ui-background: #ffffff;
      --pagefind-ui-border: #eaeaea;
      --pagefind-ui-tag: #f4f4f4;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 4px;
      --pagefind-ui-image-border-radius: 4px;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: var(--font-sans);
    }
    #search { margin-top: 2rem; }
  </style>
</BaseLayout>
