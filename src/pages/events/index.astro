---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatEventDateShort, hasTime, isPast } from '../../lib/eventDate';

const all = (await getCollection('events', ({ data }) => !data.draft));

const upcoming = all
  .filter((e) => !isPast(e.data.startDate, e.data.endDate))
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf());

const past = all
  .filter((e) => isPast(e.data.startDate, e.data.endDate))
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
---
<BaseLayout title="Events">
  <h1>Events</h1>
  <p style="color: var(--muted);">Talks, meetups, and other public appearances.</p>

  {upcoming.length === 0 && past.length === 0 && (
    <p style="color: var(--muted); margin-top: 2rem;">
      No events yet. Drop a <code>.md</code> file into <code>src/content/events/</code>.
    </p>
  )}

  {upcoming.length > 0 && (
    <section>
      <h2>Upcoming</h2>
      <ul class="entry-list">
        {upcoming.map((event) => (
          <li>
            <a class={`entry-link${event.data.image ? ' entry-link--thumb' : ''}`} href={`/events/${event.id}/`}>
              {event.data.image && (
                <img class="entry-thumb" src={event.data.image} alt="" loading="lazy" />
              )}
              <div>
                <h3>{event.data.title}</h3>
                <div class="meta">
                  {formatEventDateShort(event.data.startDate, hasTime(event.data.startDate))}
                  {event.data.location && <> · {event.data.location}</>}
                </div>
                {event.data.description && <p class="desc">{event.data.description}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {past.length > 0 && (
    <section style="margin-top: 3rem;">
      <h2>Past</h2>
      <ul class="entry-list">
        {past.map((event) => (
          <li>
            <a class={`entry-link${event.data.image ? ' entry-link--thumb' : ''}`} href={`/events/${event.id}/`}>
              {event.data.image && (
                <img class="entry-thumb" src={event.data.image} alt="" loading="lazy" />
              )}
              <div>
                <h3>{event.data.title}</h3>
                <div class="meta">
                  {formatEventDateShort(event.data.startDate, hasTime(event.data.startDate))}
                  {event.data.location && <> · {event.data.location}</>}
                </div>
                {event.data.description && <p class="desc">{event.data.description}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
